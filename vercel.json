{
  "version": 2,
  "builds": [
    { "src": "public/**/*.php", "use": "@vercel/php" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/public/index.php" },
    { "src": "^/assets/(.*)$", "dest": "/public/assets/$1" },
    { "src": "^/imgs/(.*)$", "dest": "/public/imgs/$1" },
    { "src": "^/icon/(.*)$", "dest": "/public/icon/$1" },
    { "src": "^/(.*\\.php)$", "dest": "/public/$1" }
  ]
}
